<%!-- ============================================================
     HERO
     ============================================================ --%>
<section style="background: #FFFFFF; min-height: calc(90vh - 64px);" class="flex items-center">
  <div class="w-full max-w-6xl mx-auto px-6 sm:px-10 flex flex-col md:flex-row items-center gap-12 md:gap-16 py-24">
    <%!-- Left: copy --%>
    <div class="w-full md:w-[50%] flex flex-col">
      <span
        class="thamani-badge self-start mb-8"
        style="animation: hero-in 550ms cubic-bezier(0.23,1,0.32,1) both; animation-delay: 0ms;"
      >
        GS1 Compliant · Built for Kenya
      </span>

      <h1
        class="mb-6"
        style="font-size: clamp(36px, 4.5vw, 48px); font-weight: 350; letter-spacing: -0.72px; line-height: 1.1; color: #373896; text-wrap: balance; animation: hero-in 550ms cubic-bezier(0.23,1,0.32,1) both; animation-delay: 60ms;"
      >
        The pharmacy OS <br class="hidden sm:block" />for modern Kenya.
      </h1>

      <p
        class="mb-10 max-w-lg"
        style="font-size: 18px; line-height: 1.65; color: #666666; animation: hero-in 550ms cubic-bezier(0.23,1,0.32,1) both; animation-delay: 120ms;"
      >
        One platform to manage dispensing, labs, controlled drugs, and every branch —
        all traceable to the GS1 standard.
      </p>

      <div
        class="flex flex-col sm:flex-row items-start gap-4"
        style="animation: hero-in 550ms cubic-bezier(0.23,1,0.32,1) both; animation-delay: 180ms;"
      >
        <%= if @current_scope do %>
          <a
            href={dashboard_path(@current_scope)}
            class="thamani-btn-primary"
            style="font-size: 15px; padding: 12px 28px;"
          >
            Dashboard
          </a>
        <% else %>
          <a
            href="/signup"
            class="thamani-btn-primary"
            style="font-size: 15px; padding: 12px 28px;"
          >
            Get started
          </a>
        <% end %>
        <a
          href="#features"
          class="ld-btn inline-flex items-center gap-1"
          style="font-size: 15px; color: #373896; text-decoration: underline; text-underline-offset: 3px; padding: 12px 0; background: transparent; border: none;"
        >
          See how it works →
        </a>
      </div>
    </div>

    <%!-- Right: image card --%>
    <div
      class="w-full md:w-[50%]"
      style="animation: hero-in 700ms cubic-bezier(0.23,1,0.32,1) both; animation-delay: 100ms;"
    >
      <div
        class="overflow-hidden"
        style="background: #373896; border-radius: 32px; min-height: 480px; position: relative;"
      >
        <img
          src="/images/thamanidawa-heroo.png"
          alt="ThamaniDawa pharmacy management platform"
          class="absolute inset-0 w-full h-full object-contain"
        />
      </div>
    </div>
  </div>
</section>

<%!-- ============================================================
     TRUST STRIP
     ============================================================ --%>
<section style="background: #FFFFFF; padding: 32px 24px 40px; border-bottom: 1px solid #E6EDF8;">
  <p style="text-align: center; font-size: 12px; font-weight: 500; color: #b3b3b3; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 28px;">
    Trusted by pharmacies and labs across Kenya
  </p>
  <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
    <span style="font-size: 15px; font-weight: 500; color: #c4c7c4; letter-spacing: -0.01em;">Acme Pharmacy</span>
    <span style="font-size: 15px; font-weight: 500; color: #c4c7c4; letter-spacing: -0.01em;">Acme Medical Centre</span>
    <span style="font-size: 15px; font-weight: 500; color: #c4c7c4; letter-spacing: -0.01em;">Acme Labs Kenya</span>
    <span style="font-size: 15px; font-weight: 500; color: #c4c7c4; letter-spacing: -0.01em;">Acme Health</span>
    <span style="font-size: 15px; font-weight: 500; color: #c4c7c4; letter-spacing: -0.01em;">Acme Dawa</span>
  </div>
</section>

<%!-- ============================================================
     DARK FEATURE BAND
     ============================================================ --%>
<section id="features" class="ld-dark-section" style="padding: 96px 24px;">
  <div class="max-w-6xl mx-auto">
    <p style="font-size: 12px; font-weight: 500; color: rgba(252,252,247,0.45); letter-spacing: 0.08em; text-transform: uppercase; text-align: center; margin-bottom: 16px;">
      Built for the pharmacy network owner
    </p>
    <h2
      class="text-center mx-auto mb-16"
      style="font-size: clamp(26px, 3vw, 36px); font-weight: 350; letter-spacing: -0.4px; line-height: 1.2; color: #FFFFFF; max-width: 560px; text-wrap: balance;"
    >
      Sharpen your competitive edge with modern pharmacy tools.
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      <%!-- Card 1: GS1 scan pill cycle --%>
      <div
        class="ld-feature-card reveal-item"
        style="background: var(--ld-surface); border: 1px solid var(--ld-border); border-radius: 16px; display: flex; flex-direction: column; min-height: 300px;"
      >
        <div
          class="flex flex-col items-center justify-center gap-3"
          style="flex: 1; padding: 32px 24px 24px;"
        >
          <span class="ld-scan-pill ld-active">Amoxicillin 500mg</span>
          <span class="ld-scan-pill">Panadol Advance</span>
          <span class="ld-scan-pill">Metformin 850mg</span>
        </div>
        <div style="padding: 0 32px 32px;">
          <h3
            class="mb-2"
            style="font-size: 18px; font-weight: 400; letter-spacing: -0.01em; color: var(--ld-text); line-height: 1.3;"
          >
            Full traceability
          </h3>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ld-text-muted);">
            Scan any product, get full chain of custody. Every batch, every movement,
            GS1-coded from manufacturer to patient.
          </p>
        </div>
      </div>

      <%!-- Card 2: query / answer cycle --%>
      <div
        class="ld-feature-card reveal-item"
        style="background: var(--ld-surface); border: 1px solid var(--ld-border); border-radius: 16px; display: flex; flex-direction: column; min-height: 300px;"
      >
        <div class="flex flex-col justify-center gap-3" style="flex: 1; padding: 32px 24px 24px;">
          <div
            id="ld-query-text"
            class="ld-query-bubble"
            style="opacity: 1; transform: translateY(0);"
          >
            Batch #KE2408 status?
          </div>
          <div
            id="ld-answer-text"
            class="ld-answer-bubble"
            style="opacity: 1; transform: translateY(0);"
          >
            Verified · GSK Nairobi
          </div>
        </div>
        <div style="padding: 0 32px 32px;">
          <h3
            class="mb-2"
            style="font-size: 18px; font-weight: 400; letter-spacing: -0.01em; color: var(--ld-text); line-height: 1.3;"
          >
            Instant stock answers
          </h3>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ld-text-muted);">
            Query your inventory in plain terms. Batch status, low-stock alerts,
            expiry tracking — answered from every site at once.
          </p>
        </div>
      </div>

      <%!-- Card 3: compliance progress --%>
      <div
        class="ld-feature-card reveal-item"
        style="background: var(--ld-surface); border: 1px solid var(--ld-border); border-radius: 16px; display: flex; flex-direction: column; min-height: 300px;"
      >
        <div
          class="flex flex-col items-center justify-center gap-4"
          style="flex: 1; padding: 32px 24px 24px;"
        >
          <span id="ld-sync-label" class="ld-sync-label">Syncing register...</span>
          <div class="ld-progress-track">
            <div id="ld-progress-fill" class="ld-progress-fill"></div>
          </div>
          <span class="ld-sync-sublabel">Auto-sync on every dispense</span>
        </div>
        <div style="padding: 0 32px 32px;">
          <h3
            class="mb-2"
            style="font-size: 18px; font-weight: 400; letter-spacing: -0.01em; color: var(--ld-text); line-height: 1.3;"
          >
            Compliance on autopilot
          </h3>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ld-text-muted);">
            PIN-gated dispensing and automatic audit trails keep your controlled
            drug register Kenya Pharmacy Board-ready at all times.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

