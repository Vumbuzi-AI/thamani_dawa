<%!-- ============================================================
     SCRIPTS: Card animations + scroll reveal + value prop tabs
     ============================================================ --%>
<script>
  (function () {
    // ── Scroll reveal ──────────────────────────────────────────
    var revealItems = document.querySelectorAll('.reveal-item');
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -48px 0px' });
      revealItems.forEach(function (el) { obs.observe(el); });
    } else {
      revealItems.forEach(function (el) { el.classList.add('revealed'); });
    }

    // ── Card 1: GS1 scan pill cycle ────────────────────────────
    var pills = document.querySelectorAll('.ld-scan-pill');
    if (pills.length) {
      var pillIdx = 0;
      function cyclePills() {
        pills.forEach(function (p, i) {
          if (i === pillIdx) p.classList.add('ld-active');
          else p.classList.remove('ld-active');
        });
        pillIdx = (pillIdx + 1) % pills.length;
      }
      cyclePills();
      setInterval(cyclePills, 1800);
    }

    // ── Card 2: query / answer cycle ───────────────────────────
    var qEl = document.getElementById('ld-query-text');
    var aEl = document.getElementById('ld-answer-text');
    if (qEl && aEl) {
      var qas = [
        { q: 'Batch #KE2408 status?',    a: 'Verified · GSK Nairobi'       },
        { q: 'Low stock today?',          a: '3 items below threshold'      },
        { q: 'Controlled substances?',    a: 'Schedule 4: 12 units logged'  }
      ];
      var qaIdx = 0;

      function swapIn(el, text, delay) {
        el.style.transition = 'none';
        el.style.opacity    = '0';
        el.style.transform  = 'translateY(8px)';
        el.textContent = text;
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            var go = function () {
              el.style.transition = 'opacity 380ms cubic-bezier(0.16,1,0.3,1), transform 380ms cubic-bezier(0.16,1,0.3,1)';
              el.style.opacity    = '1';
              el.style.transform  = 'translateY(0)';
            };
            delay ? setTimeout(go, delay) : go();
          });
        });
      }

      function showQA(i) { swapIn(qEl, qas[i].q, 0); swapIn(aEl, qas[i].a, 280); }
      showQA(0);
      setInterval(function () { qaIdx = (qaIdx + 1) % qas.length; showQA(qaIdx); }, 2200);
    }

    // ── Card 3: progress bar / compliance cycle ─────────────────
    var fill      = document.getElementById('ld-progress-fill');
    var syncLabel = document.getElementById('ld-sync-label');
    if (fill && syncLabel) {
      function runProgress() {
        var p = 0;
        syncLabel.textContent = 'Syncing register...';
        fill.style.width = '0%';
        var tick = setInterval(function () {
          p = Math.min(p + 4, 100);
          fill.style.width = p + '%';
          if (p >= 100) { clearInterval(tick); syncLabel.textContent = 'Register complete ✓'; }
        }, 70);
      }
      runProgress();
      setInterval(runProgress, 4500);
    }

  })();
</script>
